{
  "expo": {
    "name": "Timișoara App",
    "slug": "timisoara-app",
    "version": "0.1.0",
    "orientation": "portrait",
    "scheme": "timisoara",
    "userInterfaceStyle": "automatic",
    "splash": {
      "backgroundColor": "#ec6c21",
      "resizeMode": "contain"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.timisoara.app",
      "config": {
        "usesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#ec6c21"
      },
      "package": "com.timisoara.app"
    },
    "plugins": [
      "expo-router"
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "2fd46978-62f1-47b4-8339-802bacc1f4a8"
      }
    },
    "owner": "sorinsubulescu"
  }
}
