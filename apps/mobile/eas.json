{
  "cli": {
    "version": ">= 16.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "preview": {
      "distribution": "internal",
      "env": {
        "EXPO_PUBLIC_API_URL": "https://timisoara-app-production.up.railway.app",
        "EXPO_PUBLIC_STANDALONE_TRANSIT": "true"
      },
      "android": {
        "buildType": "apk"
      }
    },
    "preview-simulator": {
      "env": {
        "EXPO_PUBLIC_API_URL": "https://timisoara-app-production.up.railway.app",
        "EXPO_PUBLIC_STANDALONE_TRANSIT": "true"
      },
      "ios": {
        "simulator": true
      }
    },
    "production": {
      "env": {
        "EXPO_PUBLIC_API_URL": "https://timisoara-app-production.up.railway.app",
        "EXPO_PUBLIC_STANDALONE_TRANSIT": "true"
      }
    }
  }
}